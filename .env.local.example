# Productly — environment configuration
#
# Copy this file to .env.local and fill in the keys you have. Every provider
# is optional: missing keys just degrade that capability gracefully (the
# pipeline still runs end-to-end and produces a report from the mock fallback).

# ---- Decision orchestration ----------------------------------------------------
# Which reasoning model the Organizational Decision Agent uses.
# One of: qwen | zai | openai
REASONING_PROVIDER=openai

# ---- OpenAI (structured extraction + final synthesis) -------------------------
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# ---- Perplexity (grounded web research with citations) ------------------------
PERPLEXITY_API_KEY=pplx-...
PERPLEXITY_MODEL=sonar-pro

# ---- Bright Data (SERP + Web Unlocker) ----------------------------------------
# Get your API key from https://brightdata.com (Account settings → API token).
# Create two zones in the Bright Data dashboard: one of type "SERP API" and
# one of type "Web Unlocker", then paste their names below.
BRIGHTDATA_API_KEY=
BRIGHTDATA_SERP_ZONE=serp_api1
BRIGHTDATA_UNLOCKER_ZONE=web_unlocker1

# ---- Qwen Cloud (Alibaba DashScope, OpenAI-compatible endpoint) ---------------
QWEN_API_KEY=sk-...
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3-max

# ---- Z.ai (fallback reasoning model, OpenAI-compatible) -----------------------
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_MODEL=glm-4.6

# ---- EverOS Agent API (alternatives + claim verification sub-agent) -----------
# Used as a tool-using verifier agent. Endpoint shape varies by tenant; the
# adapter defaults to an OpenAI-style POST.
EVEROS_API_KEY=
EVEROS_BASE_URL=https://api.everos.ai/v1
EVEROS_AGENT_ID=

# ---- AgentField (optional: external run telemetry) ----------------------------
AGENTFIELD_API_KEY=
AGENTFIELD_BASE_URL=
AGENTFIELD_WORKFLOW_ID=
